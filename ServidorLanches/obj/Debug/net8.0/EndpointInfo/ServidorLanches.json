{
  "openapi": "3.0.1",
  "info": {
    "title": "ServidorLanches",
    "version": "1.0"
  },
  "paths": {
    "/api/auth/cardapio-completo": {
      "post": {
        "tags": [
          "Cardapio"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Login"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Login"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/usuario-logado": {
      "post": {
        "tags": [
          "Login"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/all-pedidos": {
      "post": {
        "tags": [
          "Pedido"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/pedido-info": {
      "post": {
        "tags": [
          "Pedido"
        ],
        "parameters": [
          {
            "name": "idPedido",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/add-pedido-itens": {
      "post": {
        "tags": [
          "Pedido"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pedido"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Pedido"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Pedido"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ItemPedido": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "idPedido": {
            "type": "integer",
            "format": "int32"
          },
          "idCardapio": {
            "type": "integer",
            "format": "int32"
          },
          "quantidade": {
            "type": "integer",
            "format": "int32"
          },
          "precoUnitario": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "nullable": true
          },
          "senha": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Pedido": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "idUsuario": {
            "type": "integer",
            "format": "int32"
          },
          "cpfCliente": {
            "type": "string",
            "nullable": true
          },
          "statusPedido": {
            "type": "string",
            "nullable": true
          },
          "valorTotal": {
            "type": "number",
            "format": "double"
          },
          "dataCriacao": {
            "type": "string",
            "format": "date-time"
          },
          "dataEntrega": {
            "type": "string",
            "format": "date-time"
          },
          "itens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemPedido"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}